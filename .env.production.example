# Dotloop Reporter - Production Environment Configuration
# Copy this file to .env.production and fill in your production values

# Application
NODE_ENV=production
PORT=3000

# Database (automatically injected by Manus platform)
# DATABASE_URL=mysql://user:password@host:port/database

# Authentication (automatically injected by Manus platform)
# JWT_SECRET=your-jwt-secret-here
# OAUTH_SERVER_URL=https://oauth.manus.im
# VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Manus Platform (automatically injected)
# VITE_APP_ID=your-app-id
# OWNER_OPEN_ID=owner-open-id
# OWNER_NAME=Owner Name

# Forge API (automatically injected by Manus platform)
# BUILT_IN_FORGE_API_URL=https://api.manus.im
# BUILT_IN_FORGE_API_KEY=your-api-key
# VITE_FRONTEND_FORGE_API_KEY=frontend-api-key
# VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# Dotloop OAuth (configure in Manus secrets)
# DOTLOOP_CLIENT_ID=your-dotloop-client-id
# DOTLOOP_CLIENT_SECRET=your-dotloop-client-secret
# DOTLOOP_REDIRECT_URI=https://yourdomain.com/api/dotloop/callback

# Analytics (automatically injected by Manus platform)
# VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
# VITE_ANALYTICS_WEBSITE_ID=your-website-id

# Application Settings
# VITE_APP_TITLE=Dotloop Reporter
# VITE_APP_LOGO=/logo.png

# Security
TOKEN_ENCRYPTION_KEY=generate-a-secure-random-key-here

# Health Monitoring (optional overrides)
HEALTH_CHECK_INTERVAL=30
MAX_FAILURES=3
HEALTH_CHECK_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FILE=/home/ubuntu/dotloop-reporter/logs/app.log

# Performance
MAX_UPLOAD_SIZE=52428800
CSV_PARSE_CHUNK_SIZE=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
