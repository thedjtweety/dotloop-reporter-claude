[Unit]
Description=Dotloop Reporter Health Monitor
Documentation=https://github.com/yourusername/dotloop-reporter
After=network.target dotloop-reporter.service
Requires=dotloop-reporter.service
PartOf=dotloop-reporter.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/dotloop-reporter

# Environment variables for health monitoring
Environment="NODE_ENV=production"
Environment="HEALTH_CHECK_INTERVAL=30"
Environment="HEALTH_CHECK_URL=http://localhost:3000/health"
Environment="HEALTH_CHECK_TIMEOUT=5000"
Environment="MAX_FAILURES=3"

# Start command
ExecStart=/usr/bin/node scripts/health-monitor.mjs

# Restart policy - always restart the monitor
Restart=always
RestartSec=10
StartLimitInterval=200
StartLimitBurst=10

# Resource limits (minimal for monitoring)
LimitNOFILE=1024
MemoryLimit=256M
CPUQuota=50%

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=dotloop-health-monitor

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only

# Process management
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
